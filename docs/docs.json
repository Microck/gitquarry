{
  "$schema": "https://mintlify.com/docs.json",
  "name": "gitquarry",
  "theme": "maple",
  "colors": {
    "primary": "#2563eb",
    "light": "#60a5fa",
    "dark": "#0b1220"
  },
  "logo": {
    "light": "/images/gitquarry-logo-light.svg",
    "dark": "/images/gitquarry-logo-dark.svg"
  },
  "favicon": "/images/favicon.png",
  "fonts": {
    "family": "Mona Sans",
    "source": "/fonts/mona-sans-var.woff2",
    "format": "woff2",
    "weight": 450,
    "heading": {
      "family": "Monaspace Neon",
      "source": "/fonts/monaspace-neon-var.woff2",
      "format": "woff2",
      "weight": 650
    },
    "body": {
      "family": "Mona Sans",
      "source": "/fonts/mona-sans-var.woff2",
      "format": "woff2",
      "weight": 450
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://gitquarry.micr.dev"
    }
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Microck/gitquarry"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/Microck/gitquarry/releases"
        },
        {
          "anchor": "Changelog",
          "href": "https://github.com/Microck/gitquarry/blob/main/CHANGELOG.md"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "guides/installation",
              "guides/quickstart",
              "guides/authentication",
              "guides/output-and-scripting"
            ]
          },
          {
            "group": "Search Workflow",
            "pages": [
              "guides/discovery-mode",
              "guides/search-recipes"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "guides/github-enterprise-hosts",
              "guides/shell-completion",
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Commands",
        "groups": [
          {
            "group": "Core Commands",
            "pages": [
              "commands/search",
              "commands/inspect",
              "commands/auth",
              "commands/config"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "reference/cli-overview",
              "reference/config-and-credentials",
              "reference/output-schemas"
            ]
          },
          {
            "group": "Contracts",
            "pages": [
              "reference/output-contract",
              "reference/error-reference",
              "reference/engine-internals"
            ]
          },
          {
            "group": "Behavior",
            "pages": [
              "reference/search-behavior"
            ]
          }
        ]
      },
      {
        "tab": "Project",
        "groups": [
          {
            "group": "Core Project Docs",
            "pages": [
              "project/architecture-and-spec",
              "project/specification",
              "project/architecture",
              "project/testing-and-release",
              "project/packaging-and-release",
              "project/security-and-auth-safety"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "project/development",
              "project/benchmark-study",
              "project/contributing",
              "release-runbook"
            ]
          }
        ]
      },
      {
        "tab": "Wiki",
        "groups": [
          {
            "group": "Concepts",
            "pages": [
              "wiki/native-vs-discover",
              "wiki/repository-signals",
              "wiki/faq"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "wiki/automation-patterns",
              "wiki/troubleshooting-playbook"
            ]
          }
        ]
      }
    ]
  }
}
